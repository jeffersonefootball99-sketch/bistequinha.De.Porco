<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Minha Loja</title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
background:#f5f5f5;
}

header{
background:#0f172a;
color:white;
padding:20px;
text-align:center;
}

.produtos{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:20px;
padding:30px;
}

.card{
background:white;
border-radius:10px;
box-shadow:0 0 10px rgba(0,0,0,.1);
overflow:hidden;
}

.card img{
width:100%;
height:220px;
object-fit:cover;
}

.card h2{
padding:10px;
font-size:20px;
}

.card p{
padding:0 10px;
color:#555;
}

.preco{
font-size:22px;
font-weight:bold;
color:#16a34a;
padding:10px;
}

button{
margin:10px;
width:calc(100% - 20px);
padding:12px;
background:#2563eb;
color:white;
border:none;
border-radius:8px;
cursor:pointer;
font-size:16px;
}

button:hover{
background:#1d4ed8;
}

footer{
text-align:center;
padding:20px;
background:#0f172a;
color:white;
margin-top:30px;
}
</style>

</head>

<body>

<header>
<h1>Minha Loja</h1>
<p>Produtos com os melhores preços</p>
</header>

<section class="produtos">

<div class="card">
<img src="https://picsum.photos/400/300?1">
<h2>Produto 1</h2>
<p>Descrição do produto.</p>
<div class="preco">R$ 99,90</div>

<button onclick="comprar('Produto 1')">
Comprar
</button>
</div>

<div class="card">
<img src="https://picsum.photos/400/300?2">
<h2>Produto 2</h2>
<p>Descrição do produto.</p>
<div class="preco">R$ 149,90</div>

<button onclick="comprar('Produto 2')">
Comprar
</button>
</div>

<div class="card">
<img src="https://picsum.photos/400/300?3">
<h2>Produto 3</h2>
<p>Descrição do produto.</p>
<div class="preco">R$ 249,90</div>

<button onclick="comprar('Produto 3')">
Comprar
</button>
</div>

</section>

<footer>
© 2026 Minha Loja
</footer>

<script>
function comprar(produto){
const numero="5511999999999"; // coloque seu WhatsApp
const mensagem=`Olá! Tenho interesse em comprar ${produto}.`;
window.open(`https://wa.me/${numero}?text=${encodeURIComponent(mensagem)}`);
}
</script>

</body>
</html>
